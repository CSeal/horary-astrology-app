EXPO_PUBLIC_ASTROLOGY_API_KEY=your_key_here

# Hidden developer debug mode PIN (4 digits). Leave unset in production.
# When unset the PIN gate can never be passed, so debug mode stays off.
EXPO_PUBLIC_DEBUG_PIN=4242

# Sentry DSN for crash reporting. Get from sentry.io → Project → Client Keys.
# Leave unset in dev — Sentry.init is skipped when this is absent.
EXPO_PUBLIC_SENTRY_DSN=
