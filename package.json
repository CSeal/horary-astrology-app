{
  "name": "horary-astrology",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --dev-client",
    "start:debug": "EXPO_PUBLIC_DEBUG_PIN=4242 expo start --dev-client",
    "android": "expo start --dev-client --android",
    "ios": "expo start --dev-client --ios",
    "web": "expo start --web",
    "clean": "expo start --clear",
    "doctor": "expo-doctor",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "prebuild:choose": "node scripts/prebuild-choose-team.js",
    "run:ios": "expo run:ios",
    "run:ios:device": "expo run:ios --device",
    "run:android": "expo run:android",
    "run:android:device": "expo run:android --device",
    "build:ios": "eas build -p ios --profile development --local",
    "build:android": "eas build -p android --profile development --local",
    "build:ios:preview": "eas build -p ios --profile preview --local",
    "build:android:preview": "eas build -p android --profile preview --local",
    "build:ios:prod": "eas build -p ios --profile production --local",
    "build:android:prod": "eas build -p android --profile production --local",
    "submit:ios": "eas submit -p ios --profile production",
    "submit:android": "eas submit -p android --profile production",
    "test": "jest",
    "test:table": "jest --reporters=./scripts/test-reporter.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "dependencies": {
    "@expo-google-fonts/cormorant-garamond": "^0.4.1",
    "@expo-google-fonts/inter": "^0.4.2",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.33",
    "@tanstack/react-query": "^5.100.14",
    "axios": "^1.16.1",
    "babel-preset-expo": "~55.0.8",
    "expo": "~55.0.26",
    "expo-application": "~55.0.15",
    "expo-build-properties": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-dev-client": "~55.0.35",
    "expo-font": "~55.0.8",
    "expo-haptics": "~55.0.14",
    "expo-linking": "~55.0.15",
    "expo-localization": "~55.0.15",
    "expo-location": "~55.1.10",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-store-review": "~55.0.14",
    "expo-symbols": "~55.0.9",
    "expo-system-ui": "~55.0.18",
    "expo-web-browser": "~55.0.16",
    "i18next": "^26.3.0",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.18",
    "lottie-react-native": "~7.3.4",
    "lucide-react-native": "^1.17.0",
    "nativewind": "^5.0.0-preview.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.83.6",
    "react-native-css": "^3.0.7",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "^15.15.5",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4",
    "semver": "^7.8.1",
    "use-debounce": "^10.1.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "@types/semver": "^7.7.1",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-native",
        "react-native-reanimated",
        "react-native-worklets",
        "nativewind",
        "react-native-css",
        "tailwindcss",
        "@tailwindcss/postcss",
        "postcss",
        "@tanstack/react-query",
        "i18next",
        "react-i18next",
        "zustand",
        "axios",
        "lucide-react-native",
        "expo-dev-client",
        "react-native-safe-area-context",
        "react-native-screens",
        "@gorhom/bottom-sheet",
        "lottie-react-native",
        "react-native-svg",
        "use-debounce",
        "semver"
      ]
    }
  }
}
