{
  "expo": {
    "name": "Hora",
    "slug": "hora",
    "version": "1.0.1",
    "description": "Classical horary astrology with AI interpretation. Ask a sincere question and receive an instant verdict — YES, NO, MAYBE, or UNCLEAR — cast from the chart of the moment you asked.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hora",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070714"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "io.hora.app",
      "appleTeamId": "T29RJZB64F",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Your exact location at the moment of asking is required to cast an accurate horary chart.",
        "NSUserNotificationUsageDescription": "We'll remind you to mark the outcome of your horary readings.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "io.hora.app",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#070714",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      "./plugins/withAutoSigning",
      "./plugins/withAndroidSigning",
      ["@sentry/react-native", {
        "organization": "hora",
        "project": "hora"
      }],
      "expo-dev-client",
      [
        "expo-router",
        {
          "root": "src/app"
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#1A1A2E",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Your exact location at the moment of asking is required to cast an accurate horary chart."
        }
      ],
      "expo-localization",
      "expo-system-ui",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "minSdkVersion": 24
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
